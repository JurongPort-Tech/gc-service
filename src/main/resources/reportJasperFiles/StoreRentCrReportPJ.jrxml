	<parameter name="P_REPORT_MONTH" class="java.lang.String"/>
	
	<!-- <parameter name="bill_month" isForPrompting="true" class="java.lang.String">
		<defaultValueExpression ><![CDATA["12/2050"]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select sno,discvvcd,discvoy,loadvvcd,loadvoy,pkgs,billton,acct_nbr,storerentdays, CASE WHEN totalamount = 0 THEN '' ELSE totalamount||chr(0) END totalamount,
CASE WHEN length(rownum_) = 1 THEN a.sno||'00'||rownum_
when length(rownum_) = 2  THEN a.sno||'0'||rownum_
ELSE a.sno||rownum_
END AS sno1          
from (
select c.*, rownum rownum_ from (
select 'PJ' sno, (in_vsl.vsl_nm || chr(10) || to_char(in_vsl.cod_dttm, 'DD-MON-YYYY HH24:MI')) discVvCd,
in_vsl.in_voy_nbr discVoy,
out_vsl.vsl_nm || chr(10) || es.esn_asn_nbr || chr(10) || to_char(b.atb_dttm, 'DD-MON-YYYY HH24:MI') loadVvCd,
out_vsl.out_voy_nbr loadVoy,
es.nbr_pkgs pkgs,
bi.nbr_other_unit billTon,
(select co_nm from company_code where co_cd = (select cust_cd from cust_acct where acct_nbr=bi.acct_nbr )) || chr(10) || bi.acct_nbr acct_nbr,
sum(bi.nbr_time_unit)||' Days' || chr(10) || bi.bill_nbr storeRentDays,
sum(bi.total_item_amt) totalAmount
from bill_item bi left join bill_charge bc on bi.tariff_type = bc.tariff_type and bi.bill_nbr = bc.bill_nbr and bi.item_nbr = bc.item_nbr,  
esn e, tesn_psa_jp es  left join nominated_vsl in_vsl on (upper(in_vsl.vsl_nm)=upper(es.first_car_ves_nm) and  upper(in_vsl.in_voy_nbr)= upper(es.first_car_voy_nbr) AND REC_STATUS='A' ), 
vessel_call out_vsl, berthing b
where e.esn_asn_nbr = es.esn_asn_nbr and bi.vv_cd=e.out_voy_var_nbr and b.vv_cd=e.out_voy_var_nbr and b.shift_ind=1
and out_vsl.vv_cd = e.out_voy_var_nbr and out_vsl.vv_cd = bi.vv_cd
and bi.tariff_type='C' and bi.tariff_main_cat_cd='SR'
and bi.tariff_sub_cat_cd='GL' and bi.total_item_amt>0
and out_vsl.vv_status_ind <> 'CX'
and bc.ref_ind = 'ES' and bc.ref_nbr = e.esn_asn_nbr||''  
and e.esn_status = 'A'
and to_char(b.atb_dttm, 'MM/YYYY')=$P{bill_month}
group by e.in_voy_var_nbr, in_vsl.vsl_nm, in_vsl.cod_dttm, in_vsl.in_voy_nbr, e.out_voy_var_nbr, out_vsl.vsl_nm, out_vsl.out_voy_nbr, es.esn_asn_nbr, bi.bill_nbr, bi.bill_dttm, bi.acct_nbr, es.nbr_pkgs , bi.nbr_other_unit, b.atb_dttm
)c
)a order by sno1 asc]]></queryString> -->

