<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="PONPrint" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
	<property name="ireport.scriptlethandling" value="0"/>
	<property name="ireport.encoding" value="UTF-8"/>
	<import value="net.sf.jasperreports.engine.*"/>
	<import value="java.util.*"/>
	<import value="net.sf.jasperreports.engine.data.*"/>
	<parameter name="PON_ID" class="java.lang.String">
		<defaultValueExpression><![CDATA["PBAYS2009202"]]></defaultValueExpression>
	</parameter>
	<parameter name="barcodeImage" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["barcode.png"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT TO_CHAR(passout_note.create_dttm, 'DD/MM/YYYY HH24:MI') 
		create_dttm, pon_id, truck_nbr, gate_out_dttm, pon_status, pkgs_nbr, user_nm, 
		tenant_co_cd, misc_type_nm, 'XXXXXXX' || SUBSTR(passout_note.driver_pass_id, -4) 
		AS driver_pass_id, cardhldr_name, crg_marks, crg_Desc, create_remarks, delete_remarks, 
		consignee_nm, declr_person, declr_co_nm, passout_note.nric_no, 
		logon_acct.CUST_CD FROM passout_note JOIN logon_acct ON passout_note.create_user_id = logon_acct.login_id 
		JOIN misc_type_code ON passout_note.tenant_co_cd = misc_type_code.misc_type_cd LEFT 
		JOIN jc_carddtl ON passout_note.driver_pass_id = jc_carddtl.id_no 
		WHERE pon_id = $P{PON_ID} AND misc_type_code.cat_cd = 'TENANT']]>
	</queryString>
	<field name="CREATE_DTTM" class="java.lang.String"/>
	<field name="PON_ID" class="java.lang.String"/>
	<field name="TRUCK_NBR" class="java.lang.String"/>
	<field name="GATE_OUT_DTTM" class="java.sql.Timestamp"/>
	<field name="PON_STATUS" class="java.lang.String"/>
	<field name="PKGS_NBR" class="java.math.BigDecimal"/>
	<field name="USER_NM" class="java.lang.String"/>
	<field name="TENANT_CO_CD" class="java.lang.String"/>
	<field name="MISC_TYPE_NM" class="java.lang.String"/>
	<field name="DRIVER_PASS_ID" class="java.lang.String"/>
	<field name="CARDHLDR_NAME" class="java.lang.String"/>
	<field name="CRG_MARKS" class="java.lang.String"/>
	<field name="CRG_DESC" class="java.lang.String"/>
	<field name="CREATE_REMARKS" class="java.lang.String"/>
	<field name="DELETE_REMARKS" class="java.lang.String"/>
	<field name="CONSIGNEE_NM" class="java.lang.String"/>
	<field name="DECLR_PERSON" class="java.lang.String"/>
	<field name="DECLR_CO_NM" class="java.lang.String"/>
	<field name="NRIC_NO" class="java.lang.String"/>
	<field name="CUST_CD" class="java.lang.String"/>
