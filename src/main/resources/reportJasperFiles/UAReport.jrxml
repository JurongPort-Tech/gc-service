	<queryString>
		<![CDATA[SELECT TO_CHAR(WEBDNUATEMP.DATETIME, 'DD/MM/YYYY HH24:MI') datetime,WEBDNUATEMP.TRANSREFNO AS UA_DETAILS_UA_NBR,WEBDNUATEMP.ATB,
       WEBDNUATEMP.VSLNM,WEBDNUATEMP.VOYNO,WEBDNUATEMP.CONTNO,
       WEBDNUATEMP.CONTSIZE,WEBDNUATEMP.CONTTYPE,WEBDNUATEMP.ASNNO,WEBDNUATEMP.CRGREF,
       WEBDNUATEMP.WT,WEBDNUATEMP.VOL,WEBDNUATEMP.DECLQTY,
       WEBDNUATEMP.TRANSQTY,WEBDNUATEMP.BALQTY,WEBDNUATEMP.NRICPASSPORTNO,
       WEBDNUATEMP.TRANSTYPE,WEBDNUATEMP.VEH1,WEBDNUATEMP.MARKING,
       WEBDNUATEMP.CRG_DESC,SST_BILL.ACCT_NBR_SER_CHRG,SST_BILL.EDO_ACCT_NBR,
       SST_BILL.TOTAL_AMT_SER_CHRG,SST_BILL.TOTAL_AMT_WHARF_CHRG,
       SST_BILL.TOTAL_AMT_STORE_CHRG,SST_BILL.TOTAL_AMT_SR_CHRG,
       SST_BILL.TOTAL_AMT_SER_WHARF_CHRG,SST_BILL.TARRIF_CD_SER_CHRG,
       SST_BILL.TARRIF_DESC_SER_CHRG,SST_BILL.BILLABLE_TON_SER_CHRG,
       SST_BILL.UNIT_RATE_SER_CHRG,SST_BILL.TARRIF_CD_WHARF_CHRG,
       SST_BILL.TARRIF_DESC_WHARF_CHRG,SST_BILL.BILLABLE_TON_WHARF_CHRG,
       SST_BILL.UNIT_RATE_WHARF_CHRG,SST_BILL.TARRIF_CD_STORE_CHRG,
       SST_BILL.TARRIF_DESC_STORE_CHRG,SST_BILL.BILLABLE_TON_STORE_CHRG,
       SST_BILL.UNIT_RATE_STORE_CHRG,SST_BILL.TARRIF_CD_SR_CHRG,
       SST_BILL.TARRIF_DESC_SR_CHRG,SST_BILL.BILLABLE_TON_SR_CHRG,SST_BILL.UNIT_RATE_SR_CHRG,
       SST_BILL.UNIT_RATE_SER_WHARF_CHRG,
       SST_BILL.BILLABLE_TON_SER_WHARF_CHRG,SST_BILL.TARRIF_DESC_SER_WHARF_CHRG,
       SST_BILL.TARRIF_CD_SER_WHARF_CHRG,SST_BILL.TIME_UNIT_SER,SST_BILL.TIME_UNIT_WHF,
       SST_BILL.TIME_UNIT_SR,SST_BILL.TIME_UNIT_SER_WHF,
       SST_BILL.TIME_UNIT_STORE
FROM WEBDNUATEMP WEBDNUATEMP INNER JOIN SST_BILL SST_BILL ON 
       WEBDNUATEMP.TRANSREFNO=SST_BILL.DN_UA_NBR
WHERE (WEBDNUATEMP.TRANSREFNO = $P{UaNbr})
ORDER BY WEBDNUATEMP.TRANSREFNO]]>
	</queryString>
